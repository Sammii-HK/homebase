<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>dev.sammii.heartbeat</string>

	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>/Users/sammii/development/homebase/scripts/heartbeat.sh</string>
	</array>

	<key>StartInterval</key>
	<integer>120</integer>

	<key>EnvironmentVariables</key>
	<dict>
		<key>HOMEBASE_URL</key>
		<string>https://homebase.sammii.dev</string>
		<key>HOMEBASE_SECRET</key>
		<string>REPLACE_ME</string>
	</dict>

	<key>StandardOutPath</key>
	<string>/tmp/homebase-heartbeat.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/homebase-heartbeat.log</string>

	<key>RunAtLoad</key>
	<true/>
</dict>
</plist>
